import discord
from discord.ext import commands
import os

# Настройки бота (измените на свои)
TARGET_ROLE_ID = 1367060717974454362  # ID роли, при выдаче которой создается канал
CHANNEL_NAME = '{user}'  # Имя создаваемого канала
WELCOME_MESSAGE = 'Добро пожаловать! Мы рады видеть вас на сервере!'  # Сообщение в канале

# Настройка интентов (необходимо для отслеживания обновлений участников)
intents = discord.Intents.default()
intents.members = True  # Включаем отслеживание участников

bot = commands.Bot(command_prefix='!', intents=intents)

@bot.event
async def on_ready():
    print(f'Бот {bot.user} успешно запущен!')
    print(f'Отслеживается роль с ID: {TARGET_ROLE_ID}')

@bot.event
async def on_member_update(before, after):
    """
    Событие срабатывает при изменении участника (включая добавление/удаление ролей)
    """
    # Проверяем, была ли добавлена целевая роль
    had_role_before = any(role.id == TARGET_ROLE_ID for role in before.roles)
    has_role_now = any(role.id == TARGET_ROLE_ID for role in after.roles)
    
    # Если роль была добавлена (раньше не было, теперь есть)
    if not had_role_before and has_role_now:
        await create_channel_for_member(after)

async def create_channel_for_member(member):
    """
    Создает текстовый канал для участника и отправляет приветственное сообщение
    """
    guild = member.guild
    
    # Проверяем, существует ли уже канал для этого участника
    existing_channel = discord.utils.get(guild.channels, name=f"{CHANNEL_NAME}-{member.name.lower()}")
    
    if existing_channel:
        print(f"Канал для {member.name} уже существует: {existing_channel.name}")
        return
    
    try:
        # Создаем канал в категории "Общее" или без категории
        # Можно указать конкретную категорию, если нужно
        category = discord.utils.get(guild.categories, name="Общее")
        
        # Создаем канал с именем, содержащим имя участника
        channel_name = f"{CHANNEL_NAME}-{member.name.lower()}"
        
        # Настройки прав доступа для канала
        overwrites = {
            guild.default_role: discord.PermissionOverwrite(read_messages=False),  # Запрет для всех
            member: discord.PermissionOverwrite(read_messages=True, send_messages=True),  # Разрешение для участника
            guild.me: discord.PermissionOverwrite(read_messages=True, send_messages=True)  # Разрешение для бота
        }
        
        # Создаем канал
        if category:
            channel = await guild.create_text_channel(
                channel_name,
                category=category,
                overwrites=overwrites,
                topic=f"Личный канал для {member.name}"
            )
        else:
            channel = await guild.create_text_channel(
                channel_name,
                overwrites=overwrites,
                topic=f"Личный канал для {member.name}"
            )
        
        print(f"Создан канал {channel.name} для {member.name}")
        
        # Отправляем приветственное сообщение
        await channel.send(f"{member.mention} {WELCOME_MESSAGE}")
        
        # Опционально: добавляем embed с информацией
        embed = discord.Embed(
            title="Добро пожаловать!",
            description="Это ваш личный канал. Здесь вы можете общаться с администрацией или просто чувствовать себя как дома.",
            color=discord.Color.green()
        )
        embed.set_thumbnail(url=member.avatar.url if member.avatar else member.default_avatar.url)
        embed.add_field(name="Участник", value=member.mention, inline=True)
        embed.add_field(name="Дата присоединения", value=member.joined_at.strftime("%d.%m.%Y"), inline=True)
        
        await channel.send(embed=embed)
        
    except discord.Forbidden:
        print(f"Ошибка: у бота нет прав на создание канала на сервере {guild.name}")
    except Exception as e:
        print(f"Ошибка при создании канала для {member.name}: {e}")

@bot.event
async def on_member_remove(member):
    """
    Опционально: удаляем канал, когда участник покидает сервер
    """
    guild = member.guild
    channel_name = f"{CHANNEL_NAME}-{member.name.lower()}"
    
    channel = discord.utils.get(guild.channels, name=channel_name)
    if channel:
        try:
            await channel.delete()
            print(f"Удален канал {channel_name} при выходе участника {member.name}")
        except Exception as e:
            print(f"Ошибка при удалении канала: {e}")

# Дополнительная команда для ручного создания канала (опционально)
@bot.command(name='create_channel')
@commands.has_permissions(administrator=True)
async def manual_create_channel(ctx, member: discord.Member):
    """Создает канал для указанного участника (только для админов)"""
    await create_channel_for_member(member)
    await ctx.send(f"Канал для {member.mention} создан!")

