# Команда для просмотра последних логов
@bot.command(name='show_logs')
@commands.has_permissions(administrator=True)
async def show_logs(ctx, lines: int = 10):
    """Показывает последние строки из лога (только для админов)"""
    logger.info(f"Команда !show_logs вызвана пользователем {ctx.author.name} (запрошено строк: {lines})")
    
    try:
        # Находим последний файл лога
        log_files = sorted([f for f in os.listdir('logs') if f.startswith('bot_log_')])
        if not log_files:
            await ctx.send("❌ Файлы логов не найдены")
            return
        
        latest_log = os.path.join('logs', log_files[-1])
        
        # Читаем последние строки
        with open(latest_log, 'r', encoding='utf-8') as f:
            all_lines = f.readlines()
            last_lines = all_lines[-min(lines, len(all_lines)):]
        
        # Отправляем в виде файла (чтобы не засорять чат)
        log_text = ''.join(last_lines)
        with open('temp_log.txt', 'w', encoding='utf-8') as f:
            f.write(f"Последние {len(last_lines)} строк из {latest_log}:\n\n")
            f.write(log_text)
        
        await ctx.send(file=discord.File('temp_log.txt', 'latest_log.txt'))
        os.remove('temp_log.txt')
        
        logger.info(f"Логи отправлены пользователю {ctx.author.name}")
        
    except Exception as e:
        logger.error(f"Ошибка при отправке логов: {e}")
        await ctx.send(f"❌ Ошибка при чтении логов: {e}")

@bot.event
async def on_command_error(ctx, error):
    """Обработка ошибок команд"""
    if isinstance(error, commands.MissingPermissions):
        logger.warning(f"Пользователь {ctx.author.name} попытался использовать команду без прав: {ctx.command}")
        await ctx.send("❌ У вас нет прав для использования этой команды.")
    elif isinstance(error, commands.MissingRequiredArgument):
        logger.warning(f"Пользователь {ctx.author.name} не указал обязательный аргумент в команде {ctx.command}")
        await ctx.send(f"❌ Не указан обязательный аргумент. Использование: `{ctx.command.usage}`")
    else:
        logger.error(f"Ошибка в команде {ctx.command}: {error}", exc_info=True)
        await ctx.send(f"❌ Произошла ошибка: {error}")

