@bot.event
async def on_ready():
    print(f'Бот {bot.user} успешно запущен!')

@bot.event
async def on_member_update(before, after):
    """
    Отслеживаем обновление ролей участника
    """
    # Получаем ID ролей до и после
    before_roles = set(role.id for role in before.roles)
    after_roles = set(role.id for role in after.roles)
    
    # Находим добавленные роли
    added_roles = after_roles - before_roles
    
    # Проверяем, была ли добавлена целевая роль
    if TARGET_ROLE_ID in added_roles:
        await create_channel_and_send_message(after)

async def create_channel_and_send_message(member):
    """
    Создает канал и отправляет сообщение
    """
    guild = member.guild
    
    # Формируем название канала
    channel_name = CHANNEL_NAME_TEMPLATE.format(user=member.name.lower())
    
    try:
        # Получаем категорию (если указана)
        category = None
        if CATEGORY_ID:
            category = guild.get_channel(CATEGORY_ID)
        
        # Создаем текстовый канал
        # Настраиваем права доступа: только участник с ролью и администраторы
        overwrites = {
            guild.default_role: discord.PermissionOverwrite(read_messages=False),
            member: discord.PermissionOverwrite(read_messages=True, send_messages=True),
            guild.me: discord.PermissionOverwrite(read_messages=True, send_messages=True)
        }
        
        # Добавляем права для роли с целевой ролью (опционально)
        target_role = guild.get_role(TARGET_ROLE_ID)
        if target_role:
            overwrites[target_role] = discord.PermissionOverwrite(read_messages=True, send_messages=True)
        
        # Создаем канал
        channel = await guild.create_text_channel(
            name=channel_name,
            category=category,
            overwrites=overwrites,
            reason=f"Создан для пользователя {member.name} после получения роли"
        )
        
        # Отправляем сообщение в созданный канал
        await channel.send(f"{member.mention}\n{WELCOME_MESSAGE}")
        
        print(f"Создан канал {channel.name} для пользователя {member.name}")
        
    except Exception as e:
        print(f"Ошибка при создании канала: {e}")

@bot.command()
@commands.has_permissions(administrator=True)
async def set_role(ctx, role_id: int):
    """
    Команда для установки ID целевой роли
    Использование: !set_role 123456789012345678
    """
    global TARGET_ROLE_ID
    role = ctx.guild.get_role(role_id)
    if role:
        TARGET_ROLE_ID = role_id
        await ctx.send(f"Целевая роль установлена: {role.name}")
    else:
        await ctx.send("Роль с таким ID не найдена!")

@bot.command()
@commands.has_permissions(administrator=True)
async def set_category(ctx, category_id: int):
    """
    Команда для установки ID категории
    Использование: !set_category 123456789012345678
    """
    global CATEGORY_ID
    category = ctx.guild.get_channel(category_id)
    if category and isinstance(category, discord.CategoryChannel):
        CATEGORY_ID = category_id
        await ctx.send(f"Категория установлена: {category.name}")
    else:
        await ctx.send("Категория с таким ID не найдена!")

